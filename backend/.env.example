# Copy to .env:  cp backend/.env.example backend/.env

# Central server (login / community). REQUIRED — there is NO default; set this
# yourself to the central server everyone connects to (ask whoever runs it),
# e.g. https://central.example.com  (or http://localhost:8001 if you run your own).
CENTRAL_SERVER_URL=

# Local Postgres (Docker sets its own).
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=gavel_db
DB_USER=postgres
DB_PASSWORD=

# Optional — AI generation. Key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Remote GPU (optional; default runs on this machine).
# Cluster (BGU): just run  bash cluster/setup_local.sh   (Windows: cluster\setup_local.ps1)
#   — it fills in all the cluster settings here automatically. Nothing to add by hand.
# Own GPU box:  run gavel-gpu-worker (see gavel-gpu-worker/README.md), then set:
# GPU_WORKER_URL=https://<your-worker-host>
# GPU_WORKER_TOKEN=<token you set on the worker>
