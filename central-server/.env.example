# Central server for GAVEL Cloud Platform
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values for local development.
# In production (Render), set these via the dashboard's Environment tab.

# PostgreSQL connection (Render auto-injects DATABASE_URL when you link a DB)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# JWT signing key — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=changeme-set-a-real-secret-key

# HuggingFace token (write scope) — only the central server has this
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated CORS origins allowed to call this server
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:5173

# ---------------------------------------------------------------------------
# Real-time library updates (control plane)
# ---------------------------------------------------------------------------
# The control plane watches the HF library and pushes a "version_update" to every
# connected backend the instant something is published, so users see "Updates
# available" with no polling. It runs by default; the only thing you MUST set for
# INSTANT updates is the webhook secret below. Without it, a low-frequency safety
# poll still keeps everyone converged (just not instant).
#
# Shared secret for the HuggingFace webhook. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Put the SAME value in the HF webhook's "Secret" field (see README → Real-time
# updates). Leave blank to disable webhook delivery (safety poll still runs).
REGISTRY_WEBHOOK_SECRET=

# Optional control-plane tuning (sensible defaults shown — usually leave unset):
#   ENABLE_CONTROL_PLANE=1        # set 0 to turn the control plane off entirely
#   REGISTRY_SAFETY_POLL_S=300    # backstop poll interval (s) for missed webhooks
#   REGISTRY_DEBOUNCE_S=1.0       # coalesce a burst of triggers into one reconcile
#   REGISTRY_HF_TIMEOUT_S=5.0     # strict timeout on the HF HEAD/manifest fetch
#   REGISTRY_WS_MAX_CONN=2000     # cap on concurrent notification-socket clients


